<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beranda - Healthcare</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100 font-sans">
    <!-- Header -->
    <header class="bg-blue-600 text-white p-4 shadow-md">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold">Healthcare</h1>
            <nav>
                <a href="/dashboard" class="px-3 hover:underline">Dashboard</a>
                <a href="/chatbot" class="px-3 hover:underline">Chatbot</a>
                <a href="/" class="px-3 hover:underline">Beranda</a>
                <a href="/logout" class="px-3 hover:underline">Logout</a>
            </nav>
        </div>
    </header>

    <!-- Main Content with Sidebar -->
    <div class="container mx-auto flex my-6">
        <!-- Sidebar -->
        <aside class="w-1/4 bg-white p-4 rounded-lg shadow-md mr-6">
            <h2 class="text-lg font-semibold mb-4">Semua Kategori</h2>
            <ul>
                <% categories.forEach(category => { %>
                    <li class="mb-2">
                        <a href="/category/<%= category.id %>" class="text-blue-600 hover:underline"><%= category.name %></a>
                    </li>
                <% }) %>
            </ul>
        </aside>

        <!-- Main Content -->
        <main class="w-3/4">
            <h2 class="text-2xl font-bold mb-4">Artikel Kesehataan</h2>
            <div class="mb-4">
                <input type="text" placeholder="Cari artikel..." class="w-full p-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600">
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% articles.forEach(article => { %>
                    <div class="bg-white p-4 rounded-lg shadow-md">
                        <img src="<%= article.image_url || 'https://via.placeholder.com/300' %>" alt="Article Image" class="w-full h-48 object-cover rounded-md mb-2">
                        <h3 class="text-lg font-semibold"><%= article.title %></h3>
                        <p class="text-gray-600">Kategori: <%= article.category_name %></p>
                        <a href="/article/<%= article.id %>" class="text-blue-600 hover:underline">Baca Selengkapnya</a>
                    </div>
                <% }) %>
            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="bg-blue-600 text-white p-4 text-center">
        <p>&copy; 2025 Healthcare @itenas. All rights reserved.</p>
    </footer>
</body>
</html>